{
  "name": "Phoenix Codespace Engine",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.10"
    }
  },

  "postCreateCommand": "bash scripts/init.sh",
  "postStartCommand": "bash scripts/start_tunnel.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  },
  
  "remoteEnv": {
    "HF_TOKEN": "${localEnv:HF_TOKEN}",
    "RENDER_API_URL": "${localEnv:RENDER_API_URL}",
    "HF_REPO_ID": "${localEnv:HF_REPO_ID}"
  }
}
